{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "lib": ["DOM", "DOM.Iterable", "ESNext", "ScriptHost"],
    "noImplicitAny": true,
    "target": "ESNext",
    "types": ["vitest/globals"],
    "verbatimModuleSyntax": true
  }
}
